{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "insight.schema.v1.json",
  "title": "UTS Insight Object Schema (v1.0)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "locks_version",
    "insight_id",
    "insight_title",
    "insight_statement",
    "insight_type",
    "derived_from_episodes",
    "supporting_moments",
    "life_stages_covered",
    "dominant_emotions",
    "barrier_types",
    "why_it_matters",
    "impact_vectors",
    "representative_quotes",
    "report_section_alignment",
    "suggested_calls_to_action",
    "confidence_level",
    "notes_for_editor"
  ],
  "properties": {
    "locks_version": {
      "type": "string",
      "const": "v1.0"
    },
    "insight_id": {
      "type": "string",
      "minLength": 1
    },
    "insight_title": {
      "type": "string",
      "minLength": 1
    },
    "insight_statement": {
      "type": "string",
      "minLength": 1
    },
    "insight_type": {
      "type": "string",
      "enum": [
        "systemic_pattern",
        "relational_pattern",
        "knowledge_gap_pattern",
        "behavioral_pattern",
        "emotional_pattern",
        "protective_factor",
        "risk_factor"
      ]
    },
    "derived_from_episodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supporting_moments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "moment_id",
          "episode_id",
          "speaker_role",
          "life_stage",
          "health_domain",
          "system_interaction",
          "signal_type",
          "moment_summary"
        ],
        "properties": {
          "moment_id": {
            "type": "string",
            "minLength": 1
          },
          "episode_id": {
            "type": "string",
            "minLength": 1
          },
          "speaker_role": {
            "type": "string",
            "enum": [
              "patient",
              "clinician",
              "caregiver",
              "advocate",
              "educator"
            ]
          },
          "life_stage": {
            "type": "string",
            "enum": [
              "adolescence",
              "reproductive_years",
              "postpartum",
              "menopause_transition",
              "post_menopause",
              "midlife",
              "aging",
              "cross_life_stage"
            ]
          },
          "health_domain": {
            "type": "string",
            "minLength": 1
          },
          "system_interaction": {
            "type": "string",
            "enum": [
              "healthcare_provider",
              "education_system",
              "peer_community",
              "family",
              "workplace",
              "media",
              "medical_training",
              "community_observation",
              "none"
            ]
          },
          "signal_type": {
            "type": "string",
            "minLength": 1
          },
          "moment_summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "life_stages_covered": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "adolescence",
          "reproductive_years",
          "postpartum",
          "menopause_transition",
          "post_menopause",
          "midlife",
          "aging",
          "cross_life_stage"
        ]
      }
    },
    "dominant_emotions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "barrier_types": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "why_it_matters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_level",
        "human_level",
        "equity_or_preventive_level"
      ],
      "properties": {
        "system_level": {
          "type": "string",
          "minLength": 1
        },
        "human_level": {
          "type": "string",
          "minLength": 1
        },
        "equity_or_preventive_level": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "impact_vectors": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "increased_self_advocacy",
          "peer_support",
          "behavior_change",
          "preventive_action",
          "health_literacy",
          "community_building",
          "policy_awareness",
          "care_seeking"
        ]
      }
    },
    "representative_quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "quote_type",
          "episode_id",
          "speaker_role",
          "quote_usage",
          "selection_rationale"
        ],
        "properties": {
          "quote_type": {
            "type": "string",
            "enum": [
              "primary",
              "secondary",
              "contrast"
            ]
          },
          "episode_id": {
            "type": "string",
            "minLength": 1
          },
          "speaker_role": {
            "type": "string",
            "enum": [
              "patient",
              "clinician",
              "caregiver",
              "advocate",
              "educator",
              "host"
            ]
          },
          "quote_usage": {
            "type": "string",
            "minLength": 1
          },
          "selection_rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "report_section_alignment": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "suggested_calls_to_action": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "emerging"
      ]
    },
    "notes_for_editor": {
      "type": "string"
    }
  }
}