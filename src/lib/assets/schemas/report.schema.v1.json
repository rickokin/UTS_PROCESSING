{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "report.schema.v1.json",
  "title": "UTS Insight Report Assembly Output Schema (v1.0)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "locks_version",
    "report_id",
    "report_title",
    "insight_ids_included",
    "excluded_insights",
    "life_stage_coverage",
    "confidence_distribution",
    "assembly_notes"
  ],
  "properties": {
    "locks_version": {
      "type": "string",
      "const": "v1.0"
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "report_title": {
      "type": "string",
      "minLength": 1
    },
    "insight_ids_included": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "excluded_insights": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "life_stage_coverage": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "adolescence",
          "reproductive_years",
          "pregnancy",
          "postpartum",
          "menopause_transition",
          "post_menopause",
          "midlife",
          "aging",
          "cross_life_stage"
        ]
      }
    },
    "confidence_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "high",
        "medium",
        "emerging"
      ],
      "properties": {
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "emerging": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "assembly_notes": {
      "type": "string"
    }
  }
}