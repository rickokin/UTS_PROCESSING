{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "report.schema.v1.json",
  "title": "UTS Insight Report Assembly Output Schema (v1.0)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "locks_version",
    "report_id",
    "report_title",
    "insight_ids_included",
    "excluded_insights",
    "life_stage_coverage",
    "confidence_distribution",
    "assembly_notes"
  ],
  "properties": {
    "locks_version": {
      "type": "string",
      "const": "v1.0"
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "report_title": {
      "type": "string",
      "minLength": 1
    },
    "insight_ids_included": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "excluded_insights": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "life_stage_coverage": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "adolescence",
          "reproductive_years",
          "pregnancy",
          "postpartum",
          "menopause_transition",
          "post_menopause",
          "midlife",
          "aging",
          "cross_life_stage"
        ]
      }
    },
    "confidence_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "high",
        "medium",
        "emerging"
      ],
      "properties": {
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "emerging": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "assembly_notes": {
      "type": "string"
    },
    "participant_demographics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_participants": { "type": "integer", "minimum": 0 },
        "age": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" },
            "mean": { "type": "number" },
            "median": { "type": "number" }
          },
          "required": ["min", "max", "mean", "median"]
        },
        "age_brackets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "bracket": { "type": "string" },
              "count": { "type": "integer", "minimum": 0 }
            },
            "required": ["bracket", "count"]
          }
        },
        "ethnicity_breakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "group": { "type": "string" },
              "count": { "type": "integer", "minimum": 0 },
              "pct": { "type": "number" }
            },
            "required": ["group", "count", "pct"]
          }
        },
        "geographic_scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "domestic_count": { "type": "integer", "minimum": 0 },
            "international_count": { "type": "integer", "minimum": 0 },
            "regions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "region": { "type": "string" },
                  "count": { "type": "integer", "minimum": 0 }
                },
                "required": ["region", "count"]
              }
            }
          },
          "required": ["domestic_count", "international_count", "regions"]
        }
      },
      "required": ["total_participants", "age", "age_brackets", "ethnicity_breakdown", "geographic_scope"]
    }
  }
}